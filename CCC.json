# Genera i dati JSON di una sessione F1 reale e li committa nel repository.
# Avvio: scheda "Actions" -> "Genera dati sessione F1" -> "Run workflow",
# indicando anno, GP e sessione. GitHub Pages ripubblica da solo al commit.
name: Genera dati sessione F1

on:
  workflow_dispatch:
    inputs:
      year:
        description: "Stagione (es. 2025)"
        required: true
        default: "2025"
      event:
        description: "Gran Premio (es. Monza)"
        required: true
        default: "Monza"
      session:
        description: "Sessione: FP1, FP2, FP3, Q, S, R, oppure ALL"
        required: true
        default: "R"

permissions:
  contents: write

concurrency:
  group: generate-data
  cancel-in-progress: false

jobs:
  generate:
    runs-on: ubuntu-latest
    timeout-minutes: 60
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: Installa dipendenze
        run: pip install -r tools/requirements.txt

      - name: Ripristina cache FastF1
        uses: actions/cache@v4
        with:
          path: tools/cache
          key: fastf1-${{ github.event.inputs.year }}-${{ github.event.inputs.event }}
          restore-keys: fastf1-

      - name: Genera i dati
        run: |
          if [ "${{ github.event.inputs.session }}" = "ALL" ]; then
            python tools/generate_data.py --year "${{ github.event.inputs.year }}" --event "${{ github.event.inputs.event }}" --all-sessions
          else
            python tools/generate_data.py --year "${{ github.event.inputs.year }}" --event "${{ github.event.inputs.event }}" --session "${{ github.event.inputs.session }}"
          fi

      - name: Commit dei dati generati
        run: |
          git config user.name "data-pipeline"
          git config user.email "actions@users.noreply.github.com"
          git add data
          git diff --cached --quiet && echo "Nessun dato nuovo" && exit 0
          git commit -m "dati: ${{ github.event.inputs.year }} ${{ github.event.inputs.event }} ${{ github.event.inputs.session }}"
          git push
