.site-header nav a.active { color: var(--accent-amber); }

.about {
  max-width: 960px;
  margin: 0 auto;
  padding: 64px 32px 40px;
}

.about-hero {
  margin-bottom: 48px;
  max-width: 62ch;
}

.about-hero .eyebrow {
  font-family: var(--font-display);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-amber);
  margin-bottom: 14px;
}

.about-hero h1 {
  font-size: 34px;
  font-weight: 600;
  margin: 0 0 8px;
  letter-spacing: -0.01em;
}

.about-hero .role {
  font-family: var(--font-display);
  font-size: 13px;
  color: var(--text-dim);
  margin: 0 0 20px;
}

.about-hero .lede {
  color: var(--text-dim);
  font-size: 16px;
  line-height: 1.6;
  margin: 0;
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 48px;
}

.about-card {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px 24px;
}

.about-card h2 {
  font-size: 15px;
  font-weight: 600;
  margin: 0 0 14px;
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.about-card h2 .index {
  font-family: var(--font-display);
  font-size: 12px;
  color: var(--text-faint);
  font-weight: 400;
}

.about-card ul {
  margin: 0;
  padding-left: 18px;
  color: var(--text-dim);
  font-size: 14px;
  line-height: 1.65;
}

.about-card li + li { margin-top: 10px; }

.about-card p {
  color: var(--text-dim);
  font-size: 14px;
  line-height: 1.65;
  margin: 0;
}

.about-contact {
  border-top: 1px solid var(--border);
  padding-top: 28px;
}

.about-contact h2 {
  font-size: 15px;
  font-weight: 600;
  margin: 0 0 14px;
}

.contact-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-family: var(--font-display);
  font-size: 13px;
}

.contact-list a {
  color: var(--accent-blue);
  text-decoration: none;
}
.contact-list a:hover { color: var(--accent-amber); }

@media (max-width: 720px) {
  .about-grid { grid-template-columns: 1fr; }
  .about-hero h1 { font-size: 27px; }
}
