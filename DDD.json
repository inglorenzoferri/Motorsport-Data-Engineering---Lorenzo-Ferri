/* ==========================================================================
   Design tokens
   Ispirazione: monitor di telemetria da pit-wall / timing tower.
   Niente rosso-nero-carbonio da "sito F1 generico": i colori seguono la
   convenzione reale dei canali telemetrici (velocita', acceleratore, freno).
   ========================================================================== */
:root {
  --bg: #14171a;
  --bg-panel: #1b1f24;
  --bg-panel-raised: #21262c;
  --border: #2b3138;
  --text: #e8e6e1;
  --text-dim: #8b939c;
  --text-faint: #545b62;

  --accent-amber: #c9a227;   /* accento primario: dato in evidenza */
  --accent-blue: #4a90a4;    /* canale velocita' */
  --accent-green: #6b9b5e;   /* canale acceleratore */
  --accent-red: #b3503a;     /* canale freno */

  --font-display: 'IBM Plex Mono', 'JetBrains Mono', monospace;
  --font-body: 'IBM Plex Sans', system-ui, sans-serif;

  --radius: 3px;
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.5;
}

a { color: inherit; }

/* --------------------------------------------------------------------- */
/* Header                                                                 */
/* --------------------------------------------------------------------- */
.site-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 32px;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  background: rgba(20, 23, 26, 0.92);
  backdrop-filter: blur(6px);
  z-index: 10;
}

.site-header .logo {
  font-family: var(--font-display);
  font-size: 15px;
  letter-spacing: 0.04em;
  color: var(--text);
}

.site-header .logo .dot { color: var(--accent-amber); }

.site-header .logo .logo-by {
  color: var(--text-dim);
  font-size: 11px;
  letter-spacing: 0.02em;
  text-transform: none;
}

.site-header nav {
  display: flex;
  gap: 28px;
  font-family: var(--font-display);
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.site-header nav a { text-decoration: none; }
.site-header nav a:hover { color: var(--accent-amber); }

/* --------------------------------------------------------------------- */
/* Hero: traccia telemetrica come elemento distintivo                    */
/* --------------------------------------------------------------------- */
.hero {
  padding: 72px 32px 48px;
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 48px;
  align-items: center;
  max-width: 1280px;
  margin: 0 auto;
}

.hero .eyebrow {
  font-family: var(--font-display);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-amber);
  margin-bottom: 18px;
}

.hero h1 {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 40px;
  line-height: 1.15;
  margin: 0 0 20px;
  letter-spacing: -0.01em;
}

.hero p.lede {
  color: var(--text-dim);
  font-size: 16px;
  max-width: 46ch;
  margin: 0 0 28px;
}

.hero .sources {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  font-family: var(--font-display);
  font-size: 11px;
  color: var(--text-faint);
}

.hero .sources span { border-left: 2px solid var(--border); padding-left: 8px; }

/* Oscilloscopio SVG */
.scope {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
}

.scope-header {
  display: flex;
  justify-content: space-between;
  font-family: var(--font-display);
  font-size: 11px;
  color: var(--text-faint);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.scope svg { width: 100%; height: auto; display: block; }

.scope-grid line { stroke: var(--border); stroke-width: 1; }

.trace-speed { stroke: var(--accent-blue); }
.trace-throttle { stroke: var(--accent-green); }
.trace-brake { stroke: var(--accent-red); }

.trace {
  fill: none;
  stroke-width: 2;
  stroke-dasharray: 900;
  stroke-dashoffset: 900;
  animation: draw 2.2s ease-out forwards;
}
.trace-throttle { animation-delay: 0.15s; }
.trace-brake { animation-delay: 0.3s; }

@keyframes draw {
  to { stroke-dashoffset: 0; }
}

.scope-legend {
  display: flex;
  gap: 16px;
  margin-top: 10px;
  font-family: var(--font-display);
  font-size: 11px;
  color: var(--text-dim);
}
.scope-legend .swatch { display: inline-block; width: 9px; height: 9px; border-radius: 1px; margin-right: 6px; vertical-align: middle; }
.swatch-blue { background: var(--accent-blue); }
.swatch-green { background: var(--accent-green); }
.swatch-red { background: var(--accent-red); }

@media (prefers-reduced-motion: reduce) {
  .trace { animation: none; stroke-dashoffset: 0; }
}

/* --------------------------------------------------------------------- */
/* Selettore sessione                                                     */
/* --------------------------------------------------------------------- */
.session-picker {
  max-width: 1280px;
  margin: 0 auto 40px;
  padding: 0 32px;
}

.session-picker .panel {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 24px;
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: flex-end;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.field label {
  font-family: var(--font-display);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-faint);
}

.field input, .field select {
  background: var(--bg-panel-raised);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 9px 10px;
  border-radius: var(--radius);
  font-family: var(--font-display);
  font-size: 13px;
  min-width: 130px;
}

.field input:focus, .field select:focus, button:focus-visible {
  outline: 2px solid var(--accent-amber);
  outline-offset: 1px;
}

.field-wide { flex: 1; min-width: 260px; }
.field-wide select { width: 100%; }

.status-line.sample-banner {
  color: var(--accent-amber);
  border-left: 3px solid var(--accent-amber);
  padding-left: 12px;
}

button.primary {
  background: var(--accent-amber);
  color: #14171a;
  border: none;
  padding: 10px 20px;
  border-radius: var(--radius);
  font-family: var(--font-display);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  cursor: pointer;
  font-weight: 600;
}
button.primary:hover { background: #ddb437; }

.status-line {
  font-family: var(--font-display);
  font-size: 12px;
  color: var(--text-faint);
  padding: 0 32px;
  max-width: 1280px;
  margin: -20px auto 20px;
}
.status-line.error { color: var(--accent-red); }
.status-line.ok { color: var(--accent-green); }

/* --------------------------------------------------------------------- */
/* Dashboard cards                                                        */
/* --------------------------------------------------------------------- */
.dashboard {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 32px 80px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

.card {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 12px;
}

.card-header .index {
  font-family: var(--font-display);
  color: var(--text-faint);
  font-size: 12px;
  margin-right: 10px;
}

.card-header h2 {
  font-size: 17px;
  font-weight: 600;
  margin: 0;
  display: inline;
}

.card-header .hint {
  font-family: var(--font-display);
  font-size: 11px;
  color: var(--text-faint);
}

.chart-holder { min-height: 320px; }

.driver-toggles {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 14px;
}

.driver-toggles input[type=text] {
  background: var(--bg-panel-raised);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 8px 10px;
  border-radius: var(--radius);
  font-family: var(--font-display);
  font-size: 12px;
  width: 220px;
}

.card-note {
  color: var(--text-dim);
  font-size: 13px;
  margin-top: 0;
}

a.link-button {
  text-decoration: none;
  display: inline-block;
}

table.data-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-display);
  font-size: 12.5px;
}
table.data-table th, table.data-table td {
  text-align: left;
  padding: 7px 10px;
  border-bottom: 1px solid var(--border);
}
table.data-table th {
  color: var(--text-faint);
  text-transform: uppercase;
  font-size: 10.5px;
  letter-spacing: 0.05em;
}

/* --------------------------------------------------------------------- */
/* Footer                                                                 */
/* --------------------------------------------------------------------- */
footer {
  border-top: 1px solid var(--border);
  padding: 24px 32px 40px;
  max-width: 1280px;
  margin: 0 auto;
  font-family: var(--font-display);
  font-size: 11px;
  color: var(--text-faint);
  line-height: 1.7;
}

@media (max-width: 860px) {
  .hero { grid-template-columns: 1fr; padding-top: 40px; }
  .hero h1 { font-size: 30px; }
  .site-header { flex-wrap: wrap; gap: 10px; }
  .site-header .logo { font-size: 13px; }
}
